NODE_IMAGE="node:22-alpine"
POSTGRES_IMAGE="postgres:18"

POSTGRES_DB="jobtracker"
POSTGRES_USER="jobtracker"
POSTGRES_PASSWORD="jobtracker_dev_password"
POSTGRES_PORT="15432"

# Use DATABASE_URL for host-side commands such as local Prisma or `npm run dev`.
DATABASE_URL="postgresql://jobtracker:jobtracker_dev_password@localhost:15432/jobtracker?schema=public"

# Use DOCKER_DATABASE_URL for the app container so it connects to the Docker service name.
DOCKER_DATABASE_URL="postgresql://jobtracker:jobtracker_dev_password@postgres:5432/jobtracker?schema=public"

APP_PORT="3000"

# Comma-separated hostnames/IPs accepted in the HTTP Host header.
# For production, set this to your public domain or server IP.
ALLOWED_HOSTS="localhost,127.0.0.1,[::1]"

# Set this to your public HTTPS URL before production deployment.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Set RUN_SEED=true only for first-time bootstrap or intentional reseeding.
RUN_SEED="false"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Admin User"

# Optional: seed department manager accounts and make them default auto-assignees.
# Example:
# DEPARTMENT_MANAGER_USERS_JSON='[{"name":"VAT Manager","email":"vat.manager@example.com","password":"strong-password","departmentCode":"VAT"}]'
DEPARTMENT_MANAGER_USERS_JSON=""

